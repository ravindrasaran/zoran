{
  "entities": {
    "PreRegistration": {
      "title": "PreRegistration",
      "description": "A user's pre-registration for result alerts.",
      "type": "object",
      "properties": {
        "mobile": {
          "type": "string",
          "description": "User's mobile number"
        },
        "rollNumber": {
          "type": "string",
          "description": "User's roll number"
        },
        "classType": {
          "type": "string",
          "description": "User's class (e.g., 10, 12-sci)"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of registration"
        }
      },
      "required": ["mobile", "rollNumber", "classType", "createdAt"]
    },
    "Notice": {
      "title": "Notice",
      "description": "A notice or announcement displayed on the home screen.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The text of the notice"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of creation"
        }
      },
      "required": ["text", "createdAt"]
    },
    "AdSettings": {
      "title": "AdSettings",
      "description": "Configuration for advertisements displayed in the app.",
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether ads are enabled"
        },
        "type": {
          "type": "string",
          "enum": ["custom", "adsense"],
          "description": "Type of ad to display"
        },
        "customImageUrl": {
          "type": "string",
          "description": "URL for custom image ad"
        },
        "customLinkUrl": {
          "type": "string",
          "description": "URL for custom ad link"
        },
        "adsenseClient": {
          "type": "string",
          "description": "Google AdSense client ID"
        },
        "adsenseSlot": {
          "type": "string",
          "description": "Google AdSense slot ID"
        }
      },
      "required": ["enabled", "type"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "A user's feedback or support request.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "User's name"
        },
        "email": {
          "type": "string",
          "description": "User's email"
        },
        "message": {
          "type": "string",
          "description": "User's message"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of submission"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/pre_registrations/{registrationId}": {
      "schema": { "$ref": "#/entities/PreRegistration" },
      "description": "Stores pre-registration data for result alerts."
    },
    "/notices/{noticeId}": {
      "schema": { "$ref": "#/entities/Notice" },
      "description": "Stores notices displayed on the home screen."
    },
    "/settings/ads": {
      "schema": { "$ref": "#/entities/AdSettings" },
      "description": "Stores global ad settings."
    },
    "/feedback/{feedbackId}": {
      "schema": { "$ref": "#/entities/Feedback" },
      "description": "Stores user feedback and support requests."
    }
  }
}
